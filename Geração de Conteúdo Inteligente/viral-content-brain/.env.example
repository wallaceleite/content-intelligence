# === APIs externas ===
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === Apify actors ===
APIFY_INSTAGRAM_SCRAPER_ACTOR=apify/instagram-scraper
APIFY_INSTAGRAM_REEL_ACTOR=apify/instagram-reel-scraper
APIFY_INSTAGRAM_HASHTAG_ACTOR=apify/instagram-hashtag-scraper

# === Banco ===
POSTGRES_USER=brain
POSTGRES_PASSWORD=brain
POSTGRES_DB=viral_brain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://brain:brain@localhost:5432/viral_brain

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Modelos ===
LLM_MODEL=claude-sonnet-4-6
VISION_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-large
WHISPER_MODEL=whisper-1

# === Config de análise ===
FRAME_SAMPLE_INTERVAL_SECONDS=2
VIRAL_SCORE_THRESHOLD=0.6
NICHE_SIMILARITY_THRESHOLD=0.78
MEDIA_STORAGE_DIR=./data/raw

# === App ===
LOG_LEVEL=INFO
ENVIRONMENT=development
